# Copy this file to `fastlane/.env` and fill in your App Store Connect API key info.
# (.env is read automatically by fastlane. Keep it private — do not share.)

ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Path to the .p8 key file you downloaded. Default looks for fastlane/AuthKey.p8
ASC_KEY_PATH=./fastlane/AuthKey.p8
